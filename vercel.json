{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/index.ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/favicon.ico",
      "destination": "/favicon.svg"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/index"
    },
    {
      "source": "/audio/:path*",
      "destination": "/api/index"
    },
    {
      "source": "/((?!assets/|favicon.ico).*)",
      "destination": "/index.html"
    }
  ]
}
